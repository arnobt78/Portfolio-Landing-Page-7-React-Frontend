# Vite env (used at build time)
# Leave unset or use mock-data options for production (e.g. Vercel) without a backend.

# Optional: force mock data everywhere
# VITE_USE_MOCK_DATA=true

# Optional: use Sanity in production (only if CORS is configured on Sanity)
# VITE_USE_SANITY=true

# Sanity CMS (for local dev with real data)
# VITE_SANITY_PROJECT_ID=your_project_id
# VITE_SANITY_TOKEN=your_token
